generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Domain {
  id                String             @id @default(cuid())
  name              String             @unique
  minMembersDefault Int                @default(2)
  createdAt         DateTime           @default(now())

  students          Student[]
  problemStatements ProblemStatement[]
}

model Student {
  id                 String       @id @default(cuid())
  fullName           String
  rollNumber         String       @unique
  email              String       @unique
  gender             String
  institution        String
  domainId           String
  verificationStatus String       @default("Pending")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  domain             Domain       @relation(fields: [domainId], references: [id], onDelete: Restrict)
  teams              TeamMember[]
  ledTeam            Team?        @relation("TeamLeader")

  @@index([domainId])
  @@index([verificationStatus])
}

model ProblemStatement {
  id               String   @id @default(cuid())
  title            String
  domainId         String
  minDomainMembers Int      @default(2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  domain           Domain   @relation(fields: [domainId], references: [id], onDelete: Restrict)
  teams            Team[]

  @@index([domainId])
}

model Team {
  id                  String           @id @default(cuid())
  teamName            String
  psId                String
  leaderId            String           @unique
  teamStatus          String           @default("Forming")
  memberCount         Int              @default(0)
  femaleCount         Int              @default(0)
  domainSpecificCount Int              @default(0)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  problemStatement    ProblemStatement @relation(fields: [psId], references: [id], onDelete: Restrict)
  leader              Student          @relation("TeamLeader", fields: [leaderId], references: [id], onDelete: Restrict)
  members             TeamMember[]
  evaluations         Evaluation[]
  leaderboard         Leaderboard?

  @@index([psId])
  @@index([teamStatus])
}

model TeamMember {
  teamId    String
  studentId String
  role      String   @default("Member")
  addedAt   DateTime @default(now())

  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Restrict)

  @@id([teamId, studentId])
  @@index([studentId])
}

// One score per (team, round, jury). Re-submission = upsert on @@unique.
model Evaluation {
  id          String   @id @default(cuid())
  teamId      String
  round       Int
  juryId      String
  score       Float
  feedback    String?
  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, round, juryId])
  @@index([round])
  @@index([teamId, round])
}

model Leaderboard {
  teamId       String   @id
  r1Score      Float?
  r2Score      Float?
  gfScore      Float?
  finalScore   Float?
  rankPosition Int?
  updatedAt    DateTime @updatedAt

  team         Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([finalScore])
  @@index([rankPosition])
}
